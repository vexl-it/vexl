# =============================================================================
# .easignore — controls which files EAS Build uploads in the build archive.
#
# Why this lives at the MONOREPO ROOT: when you run `eas build` from
# apps/mobile, EAS archives the WHOLE repository root (so yarn-workspaces
# dependencies resolve and `yarn install` can run at the root). Only a
# root-level ignore file can exclude root-level heavy paths like .yarn/cache.
#
# IMPORTANT: .easignore REPLACES .gitignore (it does not extend it). So this
# file must re-list everything from .gitignore that should stay out, PLUS the
# committed/working-tree artifacts that aren't needed to build the app.
#
# Do NOT exclude: any workspace package.json, the root yarn.lock / .yarnrc.yml,
# the Yarn binary/plugins/patches (.yarn/releases|plugins|patches|sdks), or
# apps/mobile/{assets,creds,src,expo-plugins,app.config.ts,...} — EAS needs
# them to install deps, run `expo prebuild`, and bundle.
# =============================================================================

# --- Dependencies & caches (EAS reinstalls fresh on the build server) ---
node_modules
.turbo

# Yarn: drop the heavy checked-in zero-install cache (~580 MB), but KEEP the
# Yarn binary, plugins, and patches that `yarn install` needs on the server.
.yarn/*
!.yarn/releases
!.yarn/plugins
!.yarn/patches
!.yarn/sdks
!.yarn/versions

# --- Build outputs / generated ---
dist
web-build/
*.jsbundle
*.tsbuildinfo
tsconfig.tsbuildinfo
.expo/
.tamagui/

# Native projects are regenerated by `expo prebuild` (CNG) on the build server.
apps/mobile/ios/
apps/mobile/android/

# --- VCS / CI / editor / OS junk ---
.git
.github
.idea
**/.idea
.vscode/
.DS_Store
*.orig.*
npm-debug.*
.planning/
.codex/
.claude/

# --- Secrets & local env (never upload) ---
.env
.env.local
*.local
*.local.*
!*.local.example
/local/*

# Signing material / build credentials (builds use remote credentials).
**/credentials/
**/credentials.json
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# --- Docs not needed to compile the app ---
docs/
