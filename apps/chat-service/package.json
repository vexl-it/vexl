{
  "name": "@vexl-next/chat-service",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "build": "node esbuild.config.js",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf ./dist",
    "format": "prettier --check \"**/*.{js,mjs,cjs,jsx,ts,tsx,md,json}\"",
    "format:fix": "prettier --write \"**/*.{js,mjs,cjs,jsx,ts,tsx,md,json}\"",
    "lint": "eslint src",
    "dev": "tsx -r dotenv/config src/index.ts",
    "start": "node --enable-source-maps dist/index.js"
  },
  "dependencies": {
    "@effect/experimental": "^0.57.11",
    "@effect/platform": "^0.93.6",
    "@effect/platform-node": "^0.103.0",
    "@effect/sql": "^0.48.6",
    "@effect/sql-pg": "^0.49.7",
    "@vexl-next/cryptography": "0.0.0",
    "@vexl-next/domain": "0.0.0",
    "@vexl-next/generic-utils": "0.0.0",
    "@vexl-next/rest-api": "0.0.0",
    "@vexl-next/server-utils": "0.0.0",
    "dayjs": "^1.11.11",
    "dotenv": "^16.4.5",
    "effect": "^3.20.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/jest": "^29.4.0",
    "@types/pg": "^8",
    "@vexl-next/esbuild": "0.0.0",
    "@vexl-next/eslint-config": "0.0.0",
    "@vexl-next/prettier-config": "0.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.20.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "rimraf": "^4.4.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.1",
    "tsx": "^4.16.0",
    "typescript": "~6.0.3"
  },
  "prettier": "@vexl-next/prettier-config"
}
