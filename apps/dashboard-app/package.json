{
  "name": "@vexl-next/dashboard-app",
  "main": "dist/server/index.cjs",
  "type": "module",
  "scripts": {
    "clean": "rimraf ./dist",
    "format": "prettier --check \"**/*.{js,mjs,cjs,jsx,ts,tsx,md,json}\"",
    "format:fix": "prettier --write \"**/*.{js,mjs,cjs,jsx,ts,tsx,md,json}\"",
    "lint": "eslint .",
    "typecheck": "tsc -p server/tsconfig.typecheck.json --pretty false && tsc -p client/tsconfig.typecheck.json --pretty false && tsc -p common/tsconfig.typecheck.json --pretty false && tsc -p vite.tsconfig.typecheck.json --pretty false",
    "build": "yarn build:server && yarn build:client",
    "build:client": "vite build",
    "build:server": "node esbuild.config.js",
    "dev": "yarn dev:server & yarn dev:client",
    "dev:server": "npx tsx server/index.ts",
    "dev:client": "vite dev",
    "dev:client:preview": "vite preview --port 5173",
    "dev:watch": "npx tsx --watch server/index.ts & vite dev",
    "start": "node dist/server/index.cjs"
  },
  "dependencies": {
    "@effect/experimental": "^0.57.11",
    "@effect/platform": "^0.93.6",
    "@effect/platform-node": "^0.103.0",
    "@effect/sql": "^0.48.6",
    "@effect/sql-pg": "^0.49.7",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@vexl-next/cryptography": "0.0.0",
    "@vexl-next/domain": "0.0.0",
    "@vexl-next/server-utils": "0.0.0",
    "dayjs": "^1.11.11",
    "dotenv": "^16.4.5",
    "effect": "^3.20.0",
    "jotai": "^2.15.0",
    "react": "19.2.3",
    "react-confetti": "^6.1.0",
    "react-dom": "19.2.3",
    "react-use": "^17.5.0",
    "serve-handler": "^6.1.5",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@formkit/auto-animate": "^0.8.2",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "@types/serve-handler": "^6",
    "@types/ws": "^8",
    "@vexl-next/eslint-config": "0.0.0",
    "@vexl-next/prettier-config": "0.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.20.0",
    "prettier": "^3.3.2",
    "rimraf": "^4.4.0",
    "ts-jest": "^29.2.0",
    "typescript": "~6.0.3",
    "vite": "^7.3.2"
  },
  "prettier": "@vexl-next/prettier-config"
}
