    "ios": "expo run:ios",
    "//test": "jest",
    "lint": "eslint src",
    "typecheck": "tsc --noemit",
    "format": "prettier --check \"**/*.{js,mjs,cjs,jsx,ts,tsx,md,json}\"",
    "format:fix": "prettier --write \"**/*.{js,mjs,cjs,jsx,ts,tsx,md,json}\"",
    "fresh-start-ios": "pnpm install && pnpm --workspace-root turbo build && expo prebuild --clean -p ios && expo run:ios",
    "fresh-start-android": "pnpm install && pnpm --workspace-root turbo build && expo prebuild --clean -p android && expo run:android",
    "e2e-test": "maestro test .maestro",
    "e2e-test-build-ios": "pnpm dlx eas-cli build --platform ios --profile build-and-maestro-test --non-interactive --no-wait",
