    "expo-status-bar": "~3.0.9",
    "jotai": "^2.15.0",
    "react": "19.1.2",
    "react-native": "0.81.5",
    "react-native-svg": "15.12.1",
    "tamagui": "^1.137.0"
  },
  "devDependencies": {
    "@babel/core": "^7.12.9",
    "@types/react": "~19.1.10",
    "@vexl-next/eslint-config": "0.0.0",
    "@vexl-next/prettier-config": "0.0.0",
    "@vexl-next/tsconfig": "0.0.0",
