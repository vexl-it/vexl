{
  "name": "@vexl-next/react-native-ecdh-platform-native-utils",
  "version": "0.0.0",
  "description": "test",
  "main": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "!lib/typescript/example",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rimraf lib tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "@vexl-next/eslint-config": "0.0.0",
    "eslint": "^9.20.0",
    "pod-install": "^0.1.0",
    "prettier": "^3.3.2",
    "react": "19.2.7",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.20.0",
    "rimraf": "^4.4.0",
    "typescript": "~6.0.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
