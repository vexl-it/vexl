{
  "name": "@vexl-next/ui",
  "version": "0.0.0",
  "type": "module",
  "main": "src/index",
  "scripts": {
    "clean": "rimraf .turbo node_modules",
    "lint": "eslint '**/*.{js,ts,tsx,jsx,cjs,mjs}'",
    "format": "prettier --check \"**/*.{js,mjs,cjs,jsx,ts,tsx,md,json}\"",
    "format:fix": "prettier --write \"**/*.{js,mjs,cjs,jsx,ts,tsx,md,json}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tamagui/shorthands": "^1.137.0",
    "tamagui": "^1.137.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "@vexl-next/eslint-config": "0.0.0",
    "@vexl-next/prettier-config": "0.0.0",
    "@vexl-next/tsconfig": "0.0.0",
    "eslint": "^8.57.1",
    "prettier": "^3.3.2",
    "react": "19.1.2",
    "react-native": "0.81.5",
    "rimraf": "^4.4.0",
    "typescript": "~5.9.2"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.81"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@vexl-next/eslint-config/react"
    ]
  },
  "prettier": "@vexl-next/prettier-config"
}
