+// Delegate to the browser-native Web Crypto API (a CSPRNG). This shim is only
+// used in browser bundles, where globalThis.crypto is always available. Never
+// fall back to a non-cryptographic source such as Math.random.
+if (!exports.getRandomValues) {
+	exports.getRandomValues = function (typedArray) {
+		return globalThis.crypto.getRandomValues(typedArray);
+	};
+}
+
+if (!exports.randomUUID) {
+	exports.randomUUID = function () {
+		return globalThis.crypto.randomUUID();
+	};
+}
