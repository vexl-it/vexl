{
  "name": "@vexl-next/generate-api-call-limits",
  "main": "dist/server/index.cjs",
  "type": "module",
  "scripts": {
    "clean": "rimraf ./dist",
    "format": "prettier --check \"**/*.{js,mjs,cjs,jsx,ts,tsx,md,json}\"",
    "format:fix": "prettier --write \"**/*.{js,mjs,cjs,jsx,ts,tsx,md,json}\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "start": "npx tsx src/index.ts",
    "check-for-missing-annotations": "npx tsx src/checkForMissingAnnotations.ts",
    "print-api-call-limits": "npx tsx src/printApiCallLimits.ts"
  },
  "dependencies": {
    "@effect/platform": "^0.93.6",
    "@effect/platform-node": "^0.103.0",
    "@vexl-next/rest-api": "0.0.0",
    "effect": "^3.20.0"
  },
  "devDependencies": {
    "@vexl-next/eslint-config": "0.0.0",
    "@vexl-next/prettier-config": "0.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.20.0",
    "prettier": "^3.3.2",
    "rimraf": "^4.4.0",
    "typescript": "~6.0.3"
  },
  "prettier": "@vexl-next/prettier-config"
}
